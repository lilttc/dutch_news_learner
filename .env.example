# Dutch News Learner - Environment Variables
# Copy to .env and fill in your values

# Required for playlist metadata (YouTube Data API v3)
# Get key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Required for segment translation (scripts/translate_segments.py)
OPENAI_API_KEY=your_openai_key_here

# Cloud Postgres (Neon) — leave unset to use local SQLite
# DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
